# Ignore everything by default. The allowlist below keeps only source code,
# lightweight configs, documentation, and dataset metadata in Git.
*

# Repository metadata and documentation
!.gitignore
!.gitattributes
!README.md
!LICENSE*

# Source scripts
!scripts/
!scripts/**

# Training/config files
!configs/
!configs/**

# Lightweight dataset metadata only
!data/
!data/yolo/
!data/yolo/*/
!data/yolo/*/dataset.yaml
!data/yolo/*/blood_ps.yaml
!data/yolo/*/manifest.csv
!data/yolo/*/dataset_stats.json

# Video-centered workflow metadata only
!videos/
!videos/*/
!videos/*/video.yaml
!videos/*/yolo/
!videos/*/yolo/*/
!videos/*/yolo/*/dataset.yaml
!videos/*/yolo/*/blood_ps.yaml
!videos/*/yolo/*/manifest.csv
!videos/*/yolo/*/dataset_stats.json

# Production model pointer/config only
!models/
!models/production/
!models/production/**

# Optional GitHub metadata if added later
!.github/
!.github/**

# Explicitly keep large/raw/generated artifacts out of Git
exports/
runs/
models/registry/
data/yolo/*/images/
data/yolo/*/labels/
videos/*/source/
videos/*/exports/
videos/*/runs/
videos/*/yolo/*/images/
videos/*/yolo/*/labels/

# Model weights and exported model binaries
*.pt
*.pth
*.onnx
*.engine
*.torchscript
*.tflite
*.pb
*.mlmodel
*.bin

# Common image/video/data artifacts
*.jpg
*.jpeg
*.png
*.bmp
*.tif
*.tiff
*.webp
*.mp4
*.avi
*.mov
*.mkv
*.csv.cache
*.cache

# Python/cache/build artifacts
**/__pycache__/
*.py[cod]
.pytest_cache/
build/
dist/
*.egg-info/

# Local environments
.venv/
venv/
env/
.env
.env.*

# OS/editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/

# Local Codex workspace metadata
.agents/
.codex/
